<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Project Demo | Showcase{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="/css/style.css" />
    {% block stylesheets %}{% endblock %}

</head>
<body>


<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
    <div class="container">
        <a class="navbar-brand text-primary fs-3 fw-bold" href="/">
            <i class="fab fa-github me-2"></i>ProjectName
        </a>

        <div class="ms-auto d-flex align-items-center gap-2">

            {% if user is defined and user is not null %}
                <a class="nav-link mx-2 fw-bold text-dark" href="/dashboard">Tableau de bord</a>
            {% else %}
                <a href="/login" class="btn btn-link text-decoration-none text-dark fw-medium">
                    Connexion
                </a>

                <a href="/register" class="btn btn-primary rounded-pill px-4">
                    S'inscrire
                </a>
            {% endif %}


            <div class="vr mx-2 d-none d-md-block"></div>

            <a href="https://github.com/mendelbellaiche/php_starterkit" target="_blank" class="btn btn-outline-dark rounded-pill px-3">
                <i class="fab fa-github"></i>
                <span class="d-none d-lg-inline ms-1">Voir sur GitHub</span>
            </a>
        </div>
    </div>
</nav>

<main>
    <div class="container mt-3">
        {% for type, messages in flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% block body %}{% endblock %}
</main>

<footer class="py-5 border-top">
    <div class="container text-center">
        <p class="text-muted mb-0">&copy; 2026 - Démo de [Nom du Repo]</p>
        <div class="mt-3">
            <a href="https://fr.linkedin.com/in/mendel-bellaiche-4a3116175" class="text-dark mx-2" target="_blank"><i class="fab fa-linkedin fa-lg"></i></a>
            <a href="#" class="text-dark mx-2"><i class="fab fa-github fa-lg"></i></a>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>